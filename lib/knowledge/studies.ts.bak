    source:
      "https://www.bak.hr/en/studijski-programi/projektni-menadzment-osijek",
  },

  zapresic: {
    role: "Sjedište Veleučilišta Baltazar",
    classicalNote:
      "Klasična nastava izvodi se u Biogradu na Moru i Osijeku.",
    onlineStudies: [
      "Poslovanje i upravljanje",
